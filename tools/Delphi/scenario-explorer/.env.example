# Get a key from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# Optional; default is claude-sonnet-4-20250514
# VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional. Override the Messages API origin. Default is same-origin `/anthropic-api`
# (Vite dev + vite preview proxy to api.anthropic.com). For static hosting, either
# proxy `/anthropic-api` on your CDN or set this to a backend that forwards to Anthropic.
# VITE_ANTHROPIC_API_BASE=https://your-worker.example.com
