# Local dev: leave unset to use Vite’s `/api` proxy (see vite.config.ts → `VITE_DEV_API_PROXY_TARGET`).
# Or set to your Worker URL to hit the API directly from the browser.
# VITE_API_BASE=https://pinboard-api.gladesystems.workers.dev

# Production builds load `.env.production` (committed) with `VITE_API_BASE` for the deployed Worker.
