VITE_MAPBOX_TOKEN=your_mapbox_token
# Dedicated Overpass endpoint (self-hosted recommended)
VITE_OVERPASS_URL=https://overpass.gladesystems.uk/api/interpreter
# Optional — UK building refinement (browser CORS may still block OS APIs)
VITE_OS_API_KEY=
# Precedents + Local Intel — dev: Vite proxies /anthropic-api → api.anthropic.com (optional client key).
VITE_ANTHROPIC_API_KEY=
# Production (Cloudflare Pages): add ANTHROPIC_API_KEY in the dashboard — do not commit real keys.
# The bundled public/_worker.js injects it when proxying /anthropic-api/* to api.anthropic.com.
# Production (Cloudflare Pages): set ANTHROPIC_API_KEY in the dashboard; public/_worker.js injects it — do not expose in the browser.
